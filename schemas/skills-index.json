{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://skills.dev/schemas/skills-index.json",
  "title": "Skills Index",
  "description": "Skill 仓库索引文件格式",
  "type": "object",
  "required": ["version", "repository", "skills"],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "repository": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["github", "gitlab", "bitbucket", "other"],
          "default": "github"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "raw_base": {
          "type": "string",
          "format": "uri",
          "description": "原始文件访问基础 URL"
        }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "path"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+"
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "author": { "type": "string" },
          "license": { "type": "string" },
          "risk_level": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "keywords": {
            "type": "array",
            "items": { "type": "string" }
          },
          "path": {
            "type": "string",
            "description": "Skill 目录路径"
          },
          "files": {
            "type": "array",
            "items": { "type": "string" },
            "description": "包含的文件列表"
          },
          "permissions": {
            "type": "object",
            "properties": {
              "files": {
                "type": "object",
                "properties": {
                  "read": { "type": "array", "items": { "type": "string" } },
                  "write": { "type": "array", "items": { "type": "string" } }
                }
              },
              "network": {
                "type": "object",
                "properties": {
                  "outbound": { "type": "array", "items": { "type": "string" } }
                }
              },
              "commands": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "dependencies": {
            "type": "object",
            "properties": {
              "skills": { "type": "array", "items": { "type": "string" } },
              "packages": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "categories": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      },
      "description": "分类索引"
    }
  }
}
